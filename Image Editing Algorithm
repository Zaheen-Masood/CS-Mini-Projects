void Blurring(int matrix [64][64][3]) {

    
   //1. storing original array into a temporary'
   
   
    int store[64][64][3];
    for(int i=0; i<64; i++) {
        for(int j=0; j<64; j++) {
        
            store[i][j][0] = matrix[i][j][0];
            store[i][j][1] = matrix[i][j][1];
            store[i][j][2] = matrix[i][j][2];	
        }
    }

        // 2.Aply kernal matrix index to that specific index
        
    for(int i=1; i<63; i++) { 
    
        for(int j=1; j<63; j++) {   // runs from 1 to 62 as its excluding borders
     
            for(int k=0; k<3; k++) {
            
                int p1 = matrix[i+1][j-1][k];  //bottom left
                int p2 = matrix[i+1][j+1][k]; // bottom right
                int p3 = matrix[i+1][j][k];   // bottom mid
                int p4 = matrix[i][j-1][k];   // middle left
                int p5 = matrix[i][j+1][k];   // middle right
                int p6 = matrix[i-1][j-1][k]; // top left
                int p7 = matrix[i-1][j+1][k]; // top right
                int p8 = matrix[i-1][j][k];   // top middle
                int p9 = matrix[i][j][k];     // middle

                int sum = (p1*1) + (p2*1) + (p3*2) + (p4*2) + (p5*2) + (p6*1) + (p7*1) + (p8*2) + (p9*4);  // apply kernal weights to specific index and add all to find sum
                
                int avg = sum / 16;
                
                store[i][j][k] = avg; // Saving the blurred PIXEL to temporary array
            }
        }
    }

    
    // save the now blurred array into the main array (matrix)
    for(int i=0; i<64; i++) {
        for(int j=0; j<64; j++) {
            for(int k=0; k<3; k++) {
                matrix[i][j][k] = store[i][j][k];
            }
        }
    }

 
// display using alpha beta gamma
    for(int i=0; i<64; i++) { 
        for(int j=0; j<64; j++) { 
            
           
            int alpha = matrix[i][j][0];
            int beta  = matrix[i][j][1];
            int gamma = matrix[i][j][2];

            
            cout << "\033[48;2;" << alpha << ";" << beta << ";" << gamma << "m";
            cout << "  "; 
            cout << "\033[0m";
        }
        
        
        cout << "\033[0m"; 
        cout << endl; 
    }
}


