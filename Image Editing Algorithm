// Clamping to see if the value at any index is greater than maximum colour value 255

int clampingfn(int num){
   
    // clamp value to 255 if greater than 255 else if it is less than 0 clamp it to 0
   
    if(num>255){
        num=255;}
    else if(num<0){
        num=0;}
       
       
        return num;
   
   
   
}



