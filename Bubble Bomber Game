 ammo = 50;
 score = 0;
 

 // initially loop through all bullets of array and set it to false so no bullets show up as a visual bug or glitch

 for(int i=0;i<bulletsize;i++){

         bulletactive[i]=false;

     
     bulletvelocityX[i]=0;    // set all bullets to zero so the bullets diont move
