//Modular Functions
//----------------------------------------//

void restoreTerminal() {
     tcsetattr(STDIN_FILENO, TCSANOW, &original_termios);  
}



void hideCursor() {
     cout << "\033[?25l";
}

void showCursor() {
     cout << "\033[?25h";
}


char getch_linux() {
     static bool first_call = true;

     if (first_call) {
         tcgetattr(STDIN_FILENO, &original_termios);
         
         atexit(restoreTerminal);
         atexit(showCursor);

         struct termios new_termios = original_termios;
         new_termios.c_lflag &= ~(ICANON | ECHO);
         new_termios.c_cc[VMIN] = 0;
         new_termios.c_cc[VTIME] = 0;
         
         tcsetattr(STDIN_FILENO, TCSANOW, &new_termios);
         
         first_call = false;
     }

     char c = 0;
     read(STDIN_FILENO, &c, 1); 
     
     return c;
}


void renderScreen(char screen[][49], int height, int width) {
     cout << "\033[H";
     for (int y = 0; y < height; ++y) {
         for (int x = 0; x < width; ++x) {
            cout << screen[y][x];
         }
         if (y < height - 1) {
            cout << "\n";
         }
     }
}


void runGame(char screen[][49], int& cannonX, bool& gameRunning,
             int height, int width, int cannonY,
             int blockrow, int blockcoulumn, int blockHealthArray[][9],
             int bulletx[], int bullety[], int bulletsize, int bulletactive[],
             int bulletvelocityX[], int bulletvelocityY[],
             int& ammo, int& score,
             int obstacleX[], int obstacleY[], char obstacleSprite[], bool obstacleActive[], int obstacleSize) 
{
     gameRunning = true;
     cannonX = width / 2; // canon initial position along X
     
     int cannonangle=0; // 0 denotes straight, 1 denotes towards right side and -1 towards leftside

     while (gameRunning) {
         char c = getch_linux(); // getch_linux() reads keyboard...
         
     
         if (c ==' ') {
             
            // when the user presses spacebar it calls the firing bullet function...
             firingthebullet(cannonX, cannonY, bulletx,bullety, bulletsize, bulletactive,
                             cannonangle, bulletvelocityX,bulletvelocityY, ammo);
             
         }else if (c == 'a' || c == 'A') {
             if (cannonX - 2 > 0) cannonX--;
         }
         else if (c == 'd' || c == 'D') {
             if (cannonX + 2 < width - 1) cannonX++;
         }else if (c == 'z' || c == 'Z') {
             cannonangle = -1;     // aim left for the canon
         }
         else if (c == 'c' || c == 'C') {
             cannonangle = 1;     // aim right for the canon
         }else if(c == 's' || c == 'S'){
             cannonangle = 0;     // aim straight for the canon
         }
         else if (c == 'q' || c == '\033') {
             gameRunning = false;
         }
         
         
         
         updategame(bulletx, bullety, bulletactive, bulletsize,
                    blockHealthArray, blockrow, blockcoulumn,
                    bulletvelocityX, bulletvelocityY, height, width,
                    score,
                    obstacleX, obstacleY, obstacleActive, obstacleSize); 
         
         // ends game if all blocks are gone or ammos are finished
  bool allBlocksGone = true;
         for(int bi = 0; bi < blockrow; bi++){
             for(int bj = 0; bj < blockcoulumn; bj++){
                 if(blockHealthArray[bi][bj] > 0){
                     allBlocksGone = false;
                     break;
                 }
             }
             if(!allBlocksGone) break;
         }

         if(allBlocksGone || ammo <= 0){
             gameRunning = false;
         }
         for (int y = 0; y < height; ++y) {
             for (int x = 0; x < width; ++x) {
                 screen[y][x] = ' ';
             }
             screen[y][width] = '\0';
         }

         for (int y = 0; y < height; ++y) {
             if (y == 0 || y == height - 1) {
                 for (int x = 0; x < width; ++x) {
                     screen[y][x] = '#';
                 }
             }
             else {
                 screen[y][0] = '#';
                 screen[y][width - 1] = '#';
             }
         }

        
     
        screen[height - 1][0] = '#';
        screen[height - 1][1] = '#';
        screen[height - 1][2] = 'A';
        screen[height - 1][3] = 'm';
        screen[height - 1][4] = 'm';
        screen[height - 1][5] = 'o';
        screen[height - 1][6] = ':';
        screen[height - 1][7] = ' ';
        screen[height - 1][8] = (ammo / 10) + '0';
        screen[height - 1][9] = (ammo % 10) + '0';
        screen[height - 1][10] = '#';
        screen[height - 1][11] = '#';

        
        
        screen[height - 1][25] = '#';
        screen[height - 1][26] = '#';
        screen[height - 1][27] = 'S';
        screen[height - 1][28] = 'c';
        screen[height - 1][29] = 'o';
        screen[height - 1][30] = 'r';
        screen[height - 1][31] = 'e';
        screen[height - 1][32] = ':';
        screen[height - 1][33] = ' ';
        screen[height - 1][34] = (score / 100) + '0';
        screen[height - 1][35] = ((score / 10) % 10) + '0';
        screen[height - 1][36] = (score % 10) + '0';
        screen[height - 1][37] = '#';
        screen[height - 1][38] = '#';
   
   // drawing the canon based on input from user
         if (cannonangle == -1) {
             screen[cannonY][cannonX - 1] = '\\';
             screen[cannonY][cannonX] = ' ';
             screen[cannonY][cannonX + 1] = '\\';
         } else if (cannonangle == 1) {
             screen[cannonY][cannonX - 1] = '/';
             screen[cannonY][cannonX] = ' ';
             screen[cannonY][cannonX + 1] = '/';
         } else {
             screen[cannonY][cannonX - 1] = '|';
             screen[cannonY][cannonX] = ' ';
             screen[cannonY][cannonX + 1] = '|';
         }
         
         
         
       // printing the bullet 'o'
         for (int i = 0; i < bulletsize; i++) {
             if (bulletactive[i]) {
                 screen[bullety[i]][bulletx[i]] = 'o';
             }
         }

  
        for (int i = 0; i < obstacleSize; i++) {
            if (obstacleActive[i]) {
                screen[obstacleY[i]][obstacleX[i]] = obstacleSprite[i];
            }
        }
       
        
         blockhealth(screen, blockrow, blockcoulumn, blockHealthArray);

         renderScreen(screen, height, width);
     
         
         usleep(16000);
     }
}




  
