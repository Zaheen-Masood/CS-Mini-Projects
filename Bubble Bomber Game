void blockhealth(char screen[][49],int blockrow,int blockcoulumn,int blockhealth[][9]){
     
  
     for(int i=0; i<blockrow; i++){
         
         
         for(int j=0; j<blockcoulumn; j++){
             
             
             int health = blockhealth[i][j];  // fetch the health of block at that index
             
             
             int screenY = i + 2; // Draw the bricks at row 2 and 3 when i is 0 and 1 respectively
             
             
             int screenX_start = 6 + (j * 4); // leaves padding and start to print the block after the padding
             
             
             // Drawing the 4-character-wide each brick depending on health
             if (health == 3) {
                 
                 screen[screenY][screenX_start + 0] = '#';
                 screen[screenY][screenX_start + 1] = '#';
                 screen[screenY][screenX_start + 2] = '#';
         screen[screenY][screenX_start + 3] = '#';
             } else if (health == 2) {
                 
                 screen[screenY][screenX_start + 0] = '=';
                 screen[screenY][screenX_start + 1] = '=';
                 screen[screenY][screenX_start + 2] = '=';
         screen[screenY][screenX_start + 3] = '=';
             } else if (health == 1) {
                
                 screen[screenY][screenX_start + 0] = '-';
                 screen[screenY][screenX_start + 1] = '-';
                 screen[screenY][screenX_start + 2] = '-';
         screen[screenY][screenX_start + 3] = '-';
             }
            
         }
     }
}



void firingthebullet(int cannonX, int cannonY, int bulletx[], int bullety[], int bulletsize, int bulletactive[],
                     int cannonAngle, int bulletvelocityX[],int bulletvelocityY[],
                     int& ammo){ 

    
    if (ammo <= 0) {
        return; // when there is no remaining ammo left to shoot
    }
    
     
     for(int i=0;i<bulletsize;i++){
         
         if(!bulletactive[i]){ // find the first inactive bullet
             
            
             bulletactive[i]=true; // set it to true and now you have a bullet you will shoot out of the canon
             bulletx[i]=cannonX; // set its position to the position of the canon in the x coordinate
             bullety[i]=cannonY-1;// the bullet will always appear above the canon so -1 the y coordinate
             
            
             bulletvelocityY[i] = -1;       // so it moves up in direction
             bulletvelocityX[i] = cannonAngle; // initially the canon fires straight upwards
             
             
             ammo--; // before returning decrement the bullet by 1
             
             
             return; // can only shoot once thus return immediately
         }
         
         
     }

}



void updategame(int bulletx[], int bullety[], int bulletactive[], int bulletsize,
                int blockhealth[][9], int blockrow, int blockcoulumn,
                int bulletvelocityX[], int bulletvelocityY[], int height, int width,
                int& score,
                int obstacleX[], int obstacleY[], bool obstacleActive[], int obstacleSize) { 
    
  
     for (int i = 0; i < bulletsize; i++) {
         
         // Check if that exact bullet is alive
         if (bulletactive[i] == true) {
             
             
             
             
             bullety[i]+= bulletvelocityY[i]; //add y velocity -1 to move upwards direction to bullets x position
             bulletx[i]+= bulletvelocityX[i];// add x velocity which can be -1,0,1 to bbullets x position
             
             
             
             
             // top wall check and reflection
             if (bullety[i] <= 0) {
             
                 bulletvelocityY[i] = 1;  // reverse the bullet if it hits the top wall  now it moves in downwarads direction (1 Y velocity)
             }
             
             // bottom wall check and kill
             if(bullety[i]>=height-1){
                 
                 bulletactive[i]=false;
             }
             
             // side wall reflections
            
             if(bulletx[i] <=1 || bulletx[i] >= width-2){
                 
             
                 bulletvelocityX[i]*=-1; // invert its x velocity
             }
             
             
             
         }
     }


    //check for collision b/w block and bullet
     
    for (int b = 0; b < bulletsize; b++) { // b serves as the bullet indeex when we iterate through the bulletactive array
         
         // Skip this bullet if it's not 'active'
         if (!bulletactive[b]) {
             continue;
         }

        //  (Check for Obstacle Collision FIRST)
        for (int o = 0; o < obstacleSize; o++) {
            if (obstacleActive[o]) {
                // Check if bullet X and Y match the obstacle's X and Y
                if (bullety[b] == obstacleY[o] && bulletx[b] == obstacleX[o]) {
                    
                  
                    
                    // "Deviate" the bullet by reflecting it along X axis
                 
                    bulletvelocityX[b] = bulletvelocityX[b] * -1; // Reflect X
                }
            }
        }
     


        // now loop through the brick for this one active bullet you just found
         
         for (int i = 0; i < blockrow; i++) {
             
             for (int j = 0; j < blockcoulumn; j++) {
                 
                 
                 if (blockhealth[i][j] > 0) { // if the brick is alive then go on else nothing will hapepen in the program
                     
                     // Get the block  position...
                     int screenY = i + 2;
                     int screenX_start = 6 + (j * 4);

                     
// check if Y position of bullet and block match...
                     if (bullety[b] == screenY && (bulletx[b] >= screenX_start && bulletx[b] < screenX_start + 4))
                     {
                         
                         
                         
                        // now that we know that the bukllet has hit we invert its Y velocity so it reflects back
                        
                         bulletvelocityY[b] = bulletvelocityY[b] * -1;
                         
                         // block health also decreases when bullet hits as it changes shape
                         blockhealth[i][j]--;

                         // score increments by 10 when user hits a block
                         score += 10;
                        
                     }
                 }
             }
         }
     }
}
