//Finding the 64 bit number from the 4 digit entered number
unsigned long long int sfbitnum(unsigned long long int x) {  //sixty four bit number

   unsigned long long int tempx = x;
   
   for (int i = 0; i < 3; i++) {
       
     x = (x * 10000) + tempx;  // tempx used for adding 1234 to the value of x to help get that 64 bit repeating number
   }
   
   return x;
}




int countOddSetBits(unsigned long long int num) {
   
   int oddsetbits = 0;

   for (int i = 1; i < 64; i += 2) {
       
       
       if((num>>i) & 1){
           
           oddsetbits++;   // find the odd set bits in the 64 bit number
       }
       
   }
   
   return oddsetbits;
}



int countEvenSetBits(unsigned long long int num) {
   
   int evensetbits = 0;

   for (int i = 0; i < 64; i += 2) {
       
       
       if((num>>i) & 1){
           
           evensetbits++;    // find the even set bits in the 64 bit number
       }
       
   }
   
   return evensetbits;
}


// checking if any number is a prime number or not
bool numisprime(int num){
   
   
   if(num<=1){
       return false;
   }
   
   for(int k=2;k<=num/2;k++){
       
       
       if(num%k==0){
           return false; // if number is divisible in by any number so its not a prime so return as false
       }
       
   }
   
   return true; // if the number is prime then the function is true
}




int nthprime(int num){ //num is eth or oth value we need to find prime of
 
   int counter=0;
   int prime=2;
   
   while(counter<num){  // finding nth prime number
       
       
       
       if(numisprime(prime)){
           
           counter++;
       }
       
       if(counter==num){  // when your counter is equal to number you are at the nth prime which you want to found
           
           return prime;
           
       }else{
           prime++;  // increment the next number from 2 to check if its prime
       }

       
   }
   return 0; // safety edge
}



// The Session Modulus (N)

int thesessionalmodulus(int p1,int e,int o){
   
   int refinedprime;
   
   if(e>=o){
       
        refinedprime = p1;  // Set RefinedPrime = RawPrime
       
       
       //Continuously add (e % 5) + 1 to RefinedPrime
       
       while(1){
           
           refinedprime+= ((e%5)+1);
           
          
           if(numisprime(refinedprime)){   // Break when RefinedPrime becomes prime again
               break;
           }
       
           }
      
       // If RefinedPrime ever goes above 61, subtract 50 from it
       
       if(refinedprime>61){
           
           refinedprime=refinedprime-50;
           
          
       
       }
       
   
       //Clamping refined prime
       
       (refinedprime<11)? refinedprime=11: (refinedprime>61)? refinedprime=61: refinedprime+=0;
       
           return refinedprime;
       
   }
   
   
   
   if(e<o){
       
       
       refinedprime = p1;  // Set RefinedPrime = RawPrime
      
      
      //Continuously add (e % 5) + 1 to RefinedPrime
      
      while(1){
          
          refinedprime-= ((o%5)+1);
          
         
          if(numisprime(refinedprime)){   // Break when RefinedPrime becomes prime again
              break;
          }
      
          }
     
       // If RefinedPrime ever goes below 11, add 50 to them
       
      if(refinedprime<11){
          
          refinedprime=refinedprime+50;
          
         
      
      }
      
  
      //Clamping refined prime
      
      (refinedprime<11)? refinedprime=11: (refinedprime>61)? refinedprime=61: refinedprime+=0;
      
          return refinedprime;
       
       return 0;
       
       
   }
   
   
   return 0;
}
 

int greatestcommondivisor(int n1,int n2) {
   
   while (n2 != 0) {  // swap until num2 is 0, when its zero the value stored in num1 is the GCD according to euclidean algorithm
       
       int temp = n2;
       n2 = n1 % n2;
       n1 = temp;
    
       
       
   }
   return n1;
}


bool Coprime(int n1, int n2) {
   return greatestcommondivisor(n1, n2) == 1;   // now if your gcd is 1 only then the number is coprime
}






unsigned long long int powerfn(unsigned long long int ascii, unsigned long long int exponent, unsigned long long int sessionmodulus ){
  unsigned long long int x=1;
 
  
  ascii = ascii % sessionmodulus;
 
  for(int i=0;i<exponent;i++){
    x = (x * ascii) % sessionmodulus;
  }
  return x;
}

